# cam-monitor credentials -- COPY to credentials.env and fill in, then chmod 600.
# credentials.env is gitignored; never commit real creds.
#
# These are the on-camera "Camera Account" creds (Tapo app -> Advanced Settings
# -> Camera Account) -- the SAME user/pass used for RTSP, ONVIF, and pytapo.
# NOT the TP-Link cloud login. Used by both cam_control.py and go2rtc.

CAM_USER=changeme
CAM_PASS=changeme
